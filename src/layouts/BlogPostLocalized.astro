---
import Layout from "./Layout.astro";
import BreadcrumbNav from "../components/BreadcrumbNav.astro";
import type { CollectionEntry } from "astro:content";
import { getSiteCopy, localePath, type Locale } from "@/i18n/site";
import { getDeepDive } from "@/content/blog/deepDive";
import { getArticleSources } from "@/content/blog/sources";

interface Props {
  post: CollectionEntry<"blog">;
  lang: Locale;
}

const { post, lang } = Astro.props;
const copy = getSiteCopy(lang);
const { title, description, pubDate, heroImage, tags, author } = post.data;
const deepDive = getDeepDive(lang, post.data.translationKey);
const articleSources = getArticleSources(lang, post.data.translationKey);

const breadcrumbItems = [
  { name: copy.blog.breadcrumbHome, href: localePath(lang, "/") },
  { name: copy.blog.breadcrumbBlog, href: localePath(lang, "/blog") },
  { name: title }
];
---

<Layout lang={lang} title={title} description={description}>
  <main class="min-h-screen bg-gradient-adaptive">
    <section class="pt-20 pb-8 px-4 max-w-4xl mx-auto">
      <BreadcrumbNav items={breadcrumbItems} homeAriaLabel={lang === "en" ? "Go home" : "Ir al inicio"} />
    </section>

    <div class="px-4 max-w-4xl mx-auto pb-16">
      <article class="bg-holy-card-bg backdrop-blur-md rounded-3xl shadow-2xl border border-holy-border overflow-hidden">
        <header class="p-8 md:p-12 bg-holy-dark-secondary/30 border-b border-holy-border">
          {heroImage && (
            <img
              src={heroImage}
              alt={title}
              class="w-full h-64 md:h-80 object-cover rounded-xl mb-8 shadow-lg"
            />
          )}

          <div class="space-y-6">
            <h1 class="font-serif text-4xl md:text-6xl font-bold text-holy-text-primary leading-tight tracking-tight">
              {title}
            </h1>

            <p class="text-xl md:text-2xl text-holy-text-secondary leading-relaxed font-light max-w-3xl">
              {description}
            </p>

            <div class="flex flex-wrap items-center gap-6 text-sm text-holy-text-secondary pt-4">
              <div class="flex items-center gap-2">
                <img
                  src="/authors/mauro.webp"
                  alt={author}
                  class="w-8 h-8 rounded-full object-cover border-2 border-holy-action shadow-lg"
                />
                <span class="font-medium">{copy.blog.by} {author}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="w-1 h-1 bg-holy-text-secondary rounded-full opacity-60"></span>
                <time datetime={pubDate.toISOString()} class="font-medium">
                  {pubDate.toLocaleDateString(lang === "en" ? "en-US" : "es-MX", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </div>
              <div class="flex items-center gap-2">
                <span class="w-1 h-1 bg-holy-text-secondary rounded-full opacity-60"></span>
                <span class="font-medium">5 {copy.blog.minRead}</span>
              </div>
            </div>

            {tags && tags.length > 0 && (
              <div class="flex flex-wrap gap-2 pt-4">
                {tags.map((tag) => (
                  <span class="px-4 py-2 bg-holy-dark-secondary/50 text-holy-text-primary rounded-full text-sm font-medium border border-holy-border">
                    #{tag}
                  </span>
                ))}
              </div>
            )}
          </div>
        </header>

        <div class="blog-body px-6 md:px-12 py-12 bg-holy-dark-primary">
          <article class="blog-content text-holy-text-primary max-w-3xl mx-auto">
            <slot />
          </article>

          {deepDive && (
            <section class="max-w-3xl mx-auto mt-12 deep-dive">
              <div class="deep-dive-kicker">{deepDive.kicker}</div>
              <p class="deep-dive-summary">{deepDive.summary}</p>
              <div class="deep-dive-grid">
                {deepDive.sections.map((section) => (
                  <article class="deep-dive-card">
                    <h3>{section.title}</h3>
                    <ul>
                      {section.items.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </article>
                ))}
              </div>
            </section>
          )}

          {articleSources.length > 0 && (
            <section class="max-w-3xl mx-auto mt-8 sources-section">
              <h3>{lang === "en" ? "Sources and context" : "Fuentes y contexto"}</h3>
              <ul>
                {articleSources.map((source) => (
                  <li>
                    <a href={source.url} target="_blank" rel="noopener noreferrer">
                      {source.label}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </div>

        <footer class="border-t border-holy-border bg-holy-card-bg px-8 md:px-12 py-12">
          <div class="max-w-2xl mx-auto text-center space-y-8">
            <h3 class="text-2xl font-semibold text-holy-text-primary mb-4">
              {copy.blog.feedbackTitle}
            </h3>
            <p class="text-holy-text-secondary text-lg leading-relaxed">
              {copy.blog.feedbackDescription}
            </p>

            <div class="flex flex-wrap justify-center gap-4">
              <a
                href={`mailto:mauro@holy-code.com?subject=${encodeURIComponent(title)}`}
                class="inline-flex items-center gap-2 px-6 py-3 bg-holy-action text-holy-text-primary rounded-full font-semibold hover:bg-holy-action/90 transition-all duration-300 hover:scale-105 shadow-lg"
              >
                💬 {copy.blog.feedbackButton}
              </a>
              <a
                href="https://www.linkedin.com/in/mesanchez91/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 bg-holy-card-bg text-holy-text-primary rounded-full font-semibold hover:bg-holy-action/20 transition-all duration-300 hover:scale-105 border border-holy-border shadow-lg"
              >
                🔗 {copy.blog.linkedinButton}
              </a>
            </div>
          </div>
        </footer>
      </article>
    </div>
  </main>
</Layout>

<style is:global>
  .blog-body {
    background: var(--holy-dark-primary);
  }

  .deep-dive {
    border-top: 1px solid var(--holy-border);
    padding-top: 2rem;
  }

  .deep-dive-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.7rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--holy-action) 45%, transparent);
    color: var(--holy-action);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.9rem;
  }

  .deep-dive-summary {
    color: var(--holy-text-secondary);
    font-size: 1.03rem;
    margin: 0 0 1.25rem;
  }

  .deep-dive-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
  }

  .deep-dive-card {
    border: 1px solid var(--holy-border);
    border-radius: 0.9rem;
    background: color-mix(in srgb, var(--holy-card-bg) 88%, transparent);
    padding: 1rem 1rem 0.85rem;
  }

  .deep-dive-card h3 {
    margin: 0 0 0.55rem;
    font-size: 1.03rem;
    line-height: 1.35;
    color: var(--holy-text-primary);
    font-family: "Poppins", system-ui, sans-serif;
  }

  .deep-dive-card ul {
    margin: 0;
    padding-left: 1.05rem;
  }

  .deep-dive-card li {
    margin: 0.3rem 0;
    color: var(--holy-text-secondary);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  @media (min-width: 900px) {
    .deep-dive-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .sources-section {
    border-top: 1px dashed var(--holy-border);
    padding-top: 1rem;
  }

  .sources-section h3 {
    margin: 0 0 0.6rem;
    font-size: 1rem;
    color: var(--holy-text-primary);
    font-family: "Poppins", system-ui, sans-serif;
  }

  .sources-section ul {
    margin: 0;
    padding-left: 1rem;
  }

  .sources-section li {
    margin: 0.35rem 0;
    color: var(--holy-text-secondary);
    font-size: 0.94rem;
  }

  .sources-section a {
    color: var(--holy-action);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-content {
    font-family: "Inter", system-ui, -apple-system, sans-serif;
    line-height: 1.85;
    letter-spacing: 0.005em;
    color: var(--holy-text-primary);
  }

  .blog-content > :first-child {
    margin-top: 0;
  }

  .blog-content h1,
  .blog-content h2,
  .blog-content h3,
  .blog-content h4 {
    font-family: "Poppins", system-ui, sans-serif;
    color: var(--holy-text-primary);
    line-height: 1.25;
    letter-spacing: -0.015em;
    margin-top: 2.25rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .blog-content h2 {
    font-size: clamp(1.5rem, 2vw, 2rem);
    border-bottom: 1px solid var(--holy-border);
    padding-bottom: 0.45rem;
  }

  .blog-content h3 {
    font-size: clamp(1.25rem, 1.6vw, 1.6rem);
  }

  .blog-content p {
    margin: 1rem 0;
    font-size: clamp(1rem, 1.1vw, 1.15rem);
    color: var(--holy-text-secondary);
  }

  .blog-content p strong {
    color: var(--holy-text-primary);
    font-weight: 700;
  }

  .blog-content a {
    color: var(--holy-action);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--holy-action) 45%, transparent);
  }

  .blog-content a:hover {
    text-decoration-color: var(--holy-action);
    opacity: 0.9;
  }

  .blog-content ul,
  .blog-content ol {
    margin: 1.25rem 0;
    padding-left: 1.25rem;
  }

  .blog-content li {
    margin: 0.45rem 0;
    color: var(--holy-text-secondary);
    font-size: clamp(1rem, 1.1vw, 1.08rem);
  }

  .blog-content blockquote {
    margin: 1.5rem 0;
    padding: 1rem 1rem 1rem 1.1rem;
    border-left: 3px solid var(--holy-action);
    border-radius: 0 10px 10px 0;
    background: color-mix(in srgb, var(--holy-action) 8%, transparent);
    color: var(--holy-text-secondary);
  }

  .blog-content hr {
    border: 0;
    border-top: 1px solid var(--holy-border);
    margin: 2rem 0;
  }

  .blog-content code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 0.93em;
    background: color-mix(in srgb, var(--holy-dark-secondary) 75%, transparent);
    color: var(--holy-action);
    border: 1px solid var(--holy-border);
    border-radius: 0.45rem;
    padding: 0.15rem 0.4rem;
  }

  .blog-content pre {
    margin: 1.5rem 0;
    border-radius: 0.8rem;
    border: 1px solid var(--holy-border);
    overflow: auto;
  }

  .blog-content pre code {
    display: block;
    border: 0;
    border-radius: 0;
    padding: 1rem;
    background: transparent;
    color: inherit;
  }

  :root:not(.dark) .blog-content p,
  :root:not(.dark) .blog-content li,
  :root:not(.dark) .blog-content blockquote {
    color: #334155;
  }

  :root:not(.dark) .blog-content h1,
  :root:not(.dark) .blog-content h2,
  :root:not(.dark) .blog-content h3,
  :root:not(.dark) .blog-content h4,
  :root:not(.dark) .blog-content p strong {
    color: #0f172a;
  }

  :root:not(.dark) .blog-content blockquote {
    background: rgba(37, 99, 235, 0.05);
    border-left-color: #2563eb;
  }
</style>
