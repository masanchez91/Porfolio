---
import Layout from "@/layouts/Layout.astro"

import AboutMe from "@/components/AboutMe.astro"
import Briefcase from "@/components/icons/Briefcase.astro"
import CodeIcon from "@/components/icons/Code.astro"
import Experience from "@/components/Experience.astro"
import ProfileCheck from "@/components/icons/ProfileCheck.astro"
import Projects from "@/components/Projects.astro"
import Services from "@/components/Services.astro"
import ContactForm from "@/components/ContactForm.astro"
import SectionContainer from "@/components/SectionContainer.astro"
import Hero from "@/components/Hero.astro"
import FloatingSocialShare from "@/components/FloatingSocialShare.astro"
---

<Layout
  title="Mauro Sánchez | Tech Lead, Full Stack Engineer & Indie Creator"
  description="Portfolio de Mauro Sánchez (The Holy Code). Proyectos reales, experiencia como Tech Lead y desarrollo de productos digitales con impacto."
>
  <main class="px-4">
    <SectionContainer id="inicio" class="py-16 md:py-36">
      <Hero />
    </SectionContainer>
    
    <div class="space-y-24">
      <SectionContainer id="proyectos">
        <h2 class="flex items-center mb-6 text-h2 font-heading font-semibold gap-x-3 text-holy-text-primary">
          <Briefcase class="size-8 text-holy-action" />
          Proyectos destacados
        </h2>
        <Projects />
      </SectionContainer>

      <SectionContainer id="experiencia">
        <h2 class="flex items-center mb-6 text-h2 font-heading font-semibold gap-x-3 text-holy-text-primary">
          <CodeIcon class="size-8 text-holy-action" />
          Experiencia laboral
        </h2>
        <Experience />
      </SectionContainer>

      <SectionContainer id="agencia">
        <h2 class="flex items-center mb-6 text-h2 font-heading font-semibold gap-x-3 text-holy-text-primary">
          <ProfileCheck class="size-8 text-holy-action" />
          Sobre Mauro y The Holy Code
        </h2>
        <AboutMe />
      </SectionContainer>

      <SectionContainer id="ecosistema">
        <h2 class="flex items-center mb-6 text-h2 font-heading font-semibold gap-x-3 text-holy-text-primary">
          <CodeIcon class="size-8 text-holy-action" />
          Ecosistema de producto
        </h2>
        <Services />
      </SectionContainer>

      <SectionContainer id="contacto">
        <ContactForm />
      </SectionContainer>

    </div>
  </main>
  
  <!-- Botones flotantes de redes sociales -->
  <FloatingSocialShare />
</Layout>
