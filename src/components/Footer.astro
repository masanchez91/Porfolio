---
import GitHub from "./icons/GitHub.astro"
import LinkedIn from "./icons/LinkedIn.astro"
import Mail from "./icons/Mail.astro"
import YouTube from "./icons/YouTube.astro"
import X from "./icons/X.astro"
import Twitch from "./icons/Twitch.astro"
import { DEFAULT_LOCALE, getSiteCopy, localePath, type Locale } from "../i18n/site"

const currentYear = new Date().getFullYear()
interface Props {
  lang?: Locale
}

const { lang = DEFAULT_LOCALE } = Astro.props
const copy = getSiteCopy(lang)
---

<footer class="relative mt-20 footer-bg border-t footer-border">
  <!-- Background gradient -->
  <div class="absolute inset-0 footer-gradient"></div>
  
  <div class="relative max-w-6xl mx-auto px-4 py-16">
    <!-- Main content -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      
      <!-- Brand section -->
      <div class="space-y-6">
        <div class="space-y-4">
          <h3 class="font-heading text-2xl font-bold text-holy-text-primary">
            The Holy Code
          </h3>
          <p class="text-holy-text-secondary leading-relaxed">
            {copy.footer.description}
          </p>
        </div>
        
        <!-- Social links -->
        <div class="flex flex-wrap gap-3">
          <a 
            href="https://github.com/masanchez91" 
            target="_blank"
            rel="noopener noreferrer"
            class="group p-3 social-btn hover:bg-holy-action/20 rounded-full transition-all duration-300 hover:scale-110 border social-border hover:border-holy-action/50"
            aria-label="GitHub"
          >
            <GitHub class="size-5 text-holy-text-secondary group-hover:text-holy-action transition-colors" />
          </a>
          <a 
            href="https://www.linkedin.com/in/mesanchez91/" 
            target="_blank"
            rel="noopener noreferrer"
            class="group p-3 social-btn hover:bg-holy-action/20 rounded-full transition-all duration-300 hover:scale-110 border social-border hover:border-holy-action/50"
            aria-label="LinkedIn"
          >
            <LinkedIn class="size-5 text-holy-text-secondary group-hover:text-holy-action transition-colors" />
          </a>
          <a 
            href="https://www.youtube.com/channel/UCROut3b1_tmEjGw4dX4fIOA" 
            target="_blank"
            rel="noopener noreferrer"
            class="group p-3 social-btn hover:bg-holy-action/20 rounded-full transition-all duration-300 hover:scale-110 border social-border hover:border-holy-action/50"
            aria-label="YouTube"
          >
            <YouTube class="size-5 text-holy-text-secondary group-hover:text-holy-action transition-colors" />
          </a>
          <a 
            href="https://www.twitch.tv/theholycode" 
            target="_blank"
            rel="noopener noreferrer"
            class="group p-3 social-btn hover:bg-holy-action/20 rounded-full transition-all duration-300 hover:scale-110 border social-border hover:border-holy-action/50"
            aria-label="Twitch"
          >
            <Twitch class="size-5 text-holy-text-secondary group-hover:text-holy-action transition-colors" />
          </a>
          <a 
            href="https://x.com/MauroSanchez25" 
            target="_blank"
            rel="noopener noreferrer"
            class="group p-3 social-btn hover:bg-holy-action/20 rounded-full transition-all duration-300 hover:scale-110 border social-border hover:border-holy-action/50"
            aria-label="X (Twitter)"
          >
            <X class="size-5 text-holy-text-secondary group-hover:text-holy-action transition-colors" />
          </a>
          <a 
            href="mailto:mauro@holy-code.com"
            class="group p-3 social-btn hover:bg-holy-action/20 rounded-full transition-all duration-300 hover:scale-110 border social-border hover:border-holy-action/50"
            aria-label="Email"
          >
            <Mail class="size-5 text-holy-text-secondary group-hover:text-holy-action transition-colors" />
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div class="space-y-6">
        <h4 class="font-heading text-lg font-semibold text-holy-text-primary">
          {copy.footer.navTitle}
        </h4>
        <nav class="space-y-3">
          <a href={localePath(lang, "/#inicio")} class="block text-holy-text-secondary hover:text-holy-action transition-colors">
            {copy.nav.home}
          </a>
          <a href={localePath(lang, "/#proyectos")} class="block text-holy-text-secondary hover:text-holy-action transition-colors">
            {copy.nav.projects}
          </a>
          <a href={localePath(lang, "/#experiencia")} class="block text-holy-text-secondary hover:text-holy-action transition-colors">
            {copy.nav.experience}
          </a>
          <a href={localePath(lang, "/#agencia")} class="block text-holy-text-secondary hover:text-holy-action transition-colors">
            {copy.nav.about}
          </a>
          <a href={localePath(lang, "/#ecosistema")} class="block text-holy-text-secondary hover:text-holy-action transition-colors">
            {copy.nav.ecosystem}
          </a>
          <a href={localePath(lang, "/#contacto")} class="block text-holy-text-secondary hover:text-holy-action transition-colors">
            {copy.nav.contact}
          </a>
          <a href={localePath(lang, "/blog")} class="block text-holy-text-secondary hover:text-holy-action transition-colors">
            {copy.footer.blogNav}
          </a>
        </nav>
      </div>

      <!-- Contact info -->
      <div class="space-y-6">
        <h4 class="font-heading text-lg font-semibold text-holy-text-primary">
          {copy.footer.contactTitle}
        </h4>
        <div class="space-y-4">
          <div class="flex items-center gap-3">
            <div class="p-2 bg-holy-action/20 rounded-lg">
              <Mail class="size-4 text-holy-action" />
            </div>
            <div>
              <p class="text-holy-text-secondary text-sm">{copy.footer.emailLabel}</p>
              <a 
                href="mailto:mauro@holy-code.com"
                class="text-holy-text-primary hover:text-holy-action transition-colors font-medium"
              >
                mauro@holy-code.com
              </a>
            </div>
          </div>
          
          <div class="footer-cta rounded-xl p-4 border border-holy-action/20">
            <p class="text-holy-text-secondary text-sm mb-2">{copy.footer.followWork}</p>
            <a 
              href={localePath(lang, "/#contacto")}
              class="inline-flex items-center gap-2 text-holy-action hover:text-holy-action/80 transition-colors font-semibold"
            >
              {copy.footer.connect}
              <span class="transform transition-transform group-hover:translate-x-1">→</span>
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="w-full h-px footer-divider mb-8"></div>

    <!-- Bottom section -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-center md:text-left">
        <p class="text-holy-text-secondary text-sm">
          {currentYear} © <span class="font-semibold text-holy-text-primary">The Holy Code</span>
        </p>
        <p class="text-holy-text-secondary text-sm mt-1">
          {copy.footer.bottomLine}
        </p>
      </div>
      
      <div class="flex items-center gap-4 text-xs text-holy-text-secondary">
        <span class="flex items-center gap-1">
          <span class="w-2 h-2 bg-holy-action rounded-full animate-pulse"></span>
          {copy.footer.status}
        </span>
      </div>
    </div>
  </div>
</footer>

<style>
  /* Footer styling for both themes */
  
  /* Default (Dark Mode) */
  .footer-bg {
    background-color: var(--holy-dark-primary);
  }
  
  .footer-border {
    border-color: rgba(255, 255, 255, 0.1);
  }
  
  .footer-gradient {
    background: linear-gradient(135deg, var(--holy-dark-primary) 0%, var(--holy-dark-secondary) 50%, var(--holy-dark-primary) 100%);
  }
  
  .social-btn {
    background-color: rgba(22, 42, 63, 0.5);
  }
  
  .social-border {
    border-color: rgba(255, 255, 255, 0.1);
  }
  
  .footer-cta {
    background-color: rgba(22, 42, 63, 0.3);
  }
  
  .footer-divider {
    background: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.3), transparent);
  }

  /* Light Mode Overrides - limpio y con contraste */
  :root:not(.dark) .footer-bg {
    background: #f8fafc;
  }
  
  :root:not(.dark) .footer-border {
    border-color: rgba(15, 23, 42, 0.1);
  }
  
  :root:not(.dark) .footer-gradient {
    background: linear-gradient(180deg, rgba(248, 250, 252, 0.96) 0%, rgba(241, 245, 249, 0.96) 100%);
  }
  
  :root:not(.dark) .social-btn {
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 4px 10px rgba(15, 23, 42, 0.08);
  }
  
  :root:not(.dark) .social-btn:hover {
    background: rgba(255, 255, 255, 1);
    box-shadow: 0 6px 14px rgba(15, 23, 42, 0.12);
  }
  
  :root:not(.dark) .social-border {
    border-color: rgba(15, 23, 42, 0.12);
  }
  
  :root:not(.dark) .footer-cta {
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
    border: 1px solid rgba(15, 23, 42, 0.12);
  }
  
  :root:not(.dark) .footer-divider {
    background: linear-gradient(to right, transparent, rgba(15, 23, 42, 0.18), transparent);
    height: 1px;
  }

  /* Enhanced animations for light mode */
  :root:not(.dark) .social-btn {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  :root:not(.dark) .social-btn:hover {
    transform: translateY(-2px) scale(1.05);
  }
  
  /* Subtle animations */
  footer {
    animation: fadeInUp 0.6s ease-out;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
