---
import ThemeToggle from "./ThemeToggle.astro"
import MobileMenu from "./MobileMenu.astro"
import { DEFAULT_LOCALE, getSiteCopy, localePath, type Locale } from "../i18n/site"
import { resolveLanguageSwitchUrls } from "../i18n/alternates"

interface Props {
  lang?: Locale
}

const { lang = DEFAULT_LOCALE } = Astro.props
const copy = getSiteCopy(lang)

const navItems = [
  { title: copy.nav.home, label: "inicio", url: localePath(lang, "/#inicio"), section: true },
  { title: copy.nav.projects, label: "proyectos", url: localePath(lang, "/#proyectos"), section: true },
  { title: copy.nav.experience, label: "experiencia", url: localePath(lang, "/#experiencia"), section: true },
  { title: copy.nav.about, label: "agencia", url: localePath(lang, "/#agencia"), section: true },
  { title: copy.nav.ecosystem, label: "ecosistema", url: localePath(lang, "/#ecosistema"), section: true },
  { title: copy.nav.contact, label: "contacto", url: localePath(lang, "/#contacto"), section: true },
  { title: copy.nav.blog, label: "blog", url: localePath(lang, "/blog"), section: false },
]

const { es: esUrl, en: enUrl } = await resolveLanguageSwitchUrls(Astro.url)
---

<header
  class="fixed top-0 z-50 flex items-center justify-center w-full mx-auto mt-2"
>
  <!-- Logo/Brand solo visible en móvil -->
  <div class="xl:hidden fixed top-4 left-4 z-50">
    <img 
      src="/holycode.webp" 
      alt="The Holy Code - Desarrollo Web México" 
      class="w-8 h-8 rounded-full"
      width="32"
      height="32"
      loading="lazy"
    />
  </div>

  <!-- Menú desktop -->
  <nav
    id="header-nav"
    class="hidden xl:flex max-w-[min(100vw-2rem,72rem)] px-4 py-2 text-sm font-medium rounded-full text-holy-text-secondary justify-center items-center backdrop-blur-sm bg-holy-dark-secondary/80 border border-holy-border"
  >
    {
      navItems.map((link) => (
        <a
          class="relative block px-3 py-2 transition hover:text-holy-action"
          aria-label={link.label}
          href={link.url}
          data-section={link.section ? link.label : undefined}
        >
          {link.title}
        </a>
      ))
    }
    
    <!-- Separador visual -->
    <div class="w-px h-6 bg-holy-neutral/30 mx-2"></div>
    
    <!-- Control de tema -->
    <div class="flex items-center">
      <ThemeToggle lang={lang} />
    </div>

    <div class="w-px h-6 bg-holy-neutral/30 mx-2"></div>
    <div class="language-switch flex items-center text-xs">
      <div class="lang-segment">
        <a href={esUrl} class={`lang-chip ${lang === "es" ? "is-active" : ""}`}>ES</a>
        <a href={enUrl} class={`lang-chip ${lang === "en" ? "is-active" : ""}`}>EN</a>
      </div>
    </div>
  </nav>

  <!-- Menú móvil - posicionado en la esquina superior derecha -->
  <div class="xl:hidden">
    <MobileMenu lang={lang} esUrl={esUrl} enUrl={enUrl} />
  </div>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const sections = document.querySelectorAll("section")
    const navItems = document.querySelectorAll("header nav a[data-section]")
    const headerNav = document.getElementById("header-nav")

    const callback = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            if (item.getAttribute("aria-label") == entry.target.id) {
              item.classList.add("text-holy-action")
              item.classList.remove("text-holy-text-secondary")
            } else {
              item.classList.remove("text-holy-action")
              item.classList.add("text-holy-text-secondary")
            }
          })
        }
      })
    }

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    })

    sections.forEach((section) => {
      observer.observe(section)
    })

    if (headerNav instanceof HTMLElement && headerNav.dataset.anchorInit !== "true") {
      navItems.forEach((item) => {
        item.addEventListener("click", (event) => {
          const href = item.getAttribute("href") || ""
          const hash = href.includes("#") ? href.split("#")[1] : ""
          if (!hash) return

          const targetId = hash
          const target = document.getElementById(targetId)
          if (!target) return

          event.preventDefault()
          history.replaceState(null, "", href)
          target.scrollIntoView({ behavior: "smooth", block: "start" })
        })
      })
      headerNav.dataset.anchorInit = "true"
    }

    // Cleanup function
    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect()
      }
    }
  })
</script>

<style>
  nav {
    animation: nav-shadown 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  @keyframes nav-shadown {
    to {
      @apply shadow-lg ring-1 backdrop-blur-md bg-holy-dark-secondary/90 ring-holy-action/20;
    }
  }

  /* Responsive breakpoints mejorados */
  @media (max-width: 1279px) {
    #header-nav a {
      padding: 0.5rem 0.75rem;
      font-size: 0.875rem;
    }
  }

  @media (max-width: 1279px) {
    #header-nav {
      display: none !important;
    }
  }

  .lang-segment {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.2rem;
    border-radius: 9999px;
    border: 1px solid var(--holy-border);
    background: color-mix(in srgb, var(--holy-dark-secondary) 70%, transparent);
  }

  .lang-chip {
    border-radius: 9999px;
    padding: 0.2rem 0.45rem;
    color: var(--holy-text-secondary);
    line-height: 1;
    transition: all 0.2s ease;
  }

  .lang-chip:hover {
    color: var(--holy-text-primary);
  }

  .lang-chip.is-active {
    color: var(--holy-action);
    background: color-mix(in srgb, var(--holy-action) 18%, transparent);
    border: 1px solid color-mix(in srgb, var(--holy-action) 55%, transparent);
  }
</style>
