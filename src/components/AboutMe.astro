---
import { DEFAULT_LOCALE, getSiteCopy, type Locale } from "../i18n/site"

interface Props {
  lang?: Locale
}

const { lang = DEFAULT_LOCALE } = Astro.props
const copy = getSiteCopy(lang)
const personalImageAlt = copy.about.imageAlt
---

<article class="flex flex-col items-center justify-center gap-12 text-holy-text-secondary md:flex-row">
  <div class="[&>p]:mb-6 [&>p>strong]:text-holy-action [&>p>strong]:font-semibold [&>p>strong]:font-heading text-pretty order-2 md:order-1 [&>p>a]:text-holy-action [&>p>a]:underline hover:[&>p>a]:text-holy-action/80 max-w-2xl">
    <p class="text-lg leading-relaxed">
      {copy.about.p1}
    </p>

    <p class="leading-relaxed">
      {copy.about.p2}
    </p>

    <p class="leading-relaxed">
      {copy.about.p3}
    </p>

    <div class="bg-holy-dark-secondary/30 backdrop-blur-sm rounded-2xl p-6 border border-holy-action/20 mt-8">
      <h3 class="font-heading text-xl font-semibold text-holy-text-primary mb-4">
        {copy.about.differentiatorTitle}
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
        {copy.about.points.map((point) => (
          <div class="flex items-start gap-2">
            <span class="w-2 h-2 bg-holy-action rounded-full mt-2 flex-shrink-0"></span>
            <div>
              <strong class="text-holy-text-primary">{point.title}</strong>
              <p class="text-holy-text-secondary">{point.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="order-1 md:order-2 flex-shrink-0">
    <img 
      loading="lazy" 
      width="300" 
      height="300" 
      src="/me.webp" 
      alt={personalImageAlt} 
      class="object-cover w-72 h-72 p-2 bg-holy-dark-secondary/50 backdrop-blur-sm rotate-3 rounded-3xl border border-holy-action/20 transition-transform duration-300 ease-in-out hover:scale-105 hover:rotate-0 animate-float shadow-xl" 
      style="object-position: 50% 50%"
    />
    <div class="text-center mt-4">
      <p class="text-holy-text-primary font-heading font-semibold">Mauro Sánchez</p>
      <p class="text-holy-text-secondary text-sm">{copy.about.roleLine}</p>
      <div class="flex justify-center gap-2 mt-2">
        <a 
          href="https://twitch.tv/holycode" 
          target="_blank" 
          rel="noopener noreferrer"
          class="text-holy-action hover:text-holy-action/80 transition-colors text-sm"
        >
          Twitch
        </a>
        <span class="text-holy-text-secondary">•</span>
        <a 
          href="https://linkedin.com/in/mesanchez91" 
          target="_blank" 
          rel="noopener noreferrer"
          class="text-holy-action hover:text-holy-action/80 transition-colors text-sm"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</article>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0px) rotate(3deg);
    }
    50% {
      transform: translateY(-12px) rotate(3deg);
    }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
</style>
