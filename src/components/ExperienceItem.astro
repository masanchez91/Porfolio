---
import LinkInline from "./LinkInline.astro"

interface Props {
  title: string
  company: string
  description: string
  link?: string
  date: string
  moreLabel?: string
}

const { title, company, description, link, date, moreLabel = "Saber más" } = Astro.props
---

<div
  class="relative ml-6 md:ml-12 pb-10 md:pb-12 grid md:grid-cols-5 md:gap-8 before:absolute before:left-[-18px] md:before:left-[-35px] before:block before:h-full before:border-l-2 before:border-white/15 before:content-['']"
>
  <div class="relative pb-6 md:pb-12 md:col-span-2">
    <div class="md:sticky md:top-24">
      <span class="text-yellow-400 -left-[24px] md:-left-[42px] absolute rounded-full text-4xl md:text-5xl"
        >&bull;</span
      >

      <h3 class="text-lg md:text-xl font-bold text-yellow-400">{title}</h3>
      <h4 class="font-semibold text-lg md:text-xl text-gray-600 dark:text-white">{company}</h4>
      <time class="p-0 m-0 text-sm text-gray-600/80 dark:text-white/80">{date}</time>
    </div>
  </div>
  <div class="relative flex flex-col gap-2 pb-3 md:pb-4 text-gray-600 dark:text-gray-300 md:col-span-3">
    {description}
    {
      link && (
        <LinkInline href={link}>
          {moreLabel}{" "}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 icon icon-tabler icon-tabler-chevron-right"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M9 6l6 6l-6 6" />
          </svg>
        </LinkInline>
      )
    }
  </div>
</div>
