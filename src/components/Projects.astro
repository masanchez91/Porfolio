---
import LinkButton from "./LinkButton.astro"
import Link from "./icons/Link.astro"
import { DEFAULT_LOCALE, getSiteCopy, localePath, type Locale } from "../i18n/site"

interface Props {
  lang?: Locale
}

const { lang = DEFAULT_LOCALE } = Astro.props
const copy = getSiteCopy(lang)
---

<div class="space-y-10">
  <div class="max-w-3xl">
    <h3 class="font-heading text-2xl font-semibold text-holy-text-primary mb-3">
      {copy.projects.title}
    </h3>
    <p class="text-holy-text-secondary leading-relaxed">
      {copy.projects.description}
    </p>
  </div>

  <div class="grid gap-6 xl:grid-cols-2">
    {copy.projects.items.map((project) => (
      <article class="min-w-0 rounded-2xl border border-holy-border bg-holy-card-bg p-5 md:p-6 backdrop-blur-sm hover:-translate-y-1 transition-all duration-300">
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0">
            <h4 class="font-heading text-xl font-semibold text-holy-text-primary break-words">{project.title}</h4>
            <p class="text-sm text-holy-action mt-1">{project.subtitle}</p>
          </div>
          <span class="shrink-0 text-xs px-2 py-1 rounded-full border border-holy-action/30 text-holy-action bg-holy-action/10">
            {project.status}
          </span>
        </div>

        <div class="mt-5 space-y-3 text-sm text-holy-text-secondary">
          <p><strong class="text-holy-text-primary">{copy.projects.roleLabel}:</strong> {project.role}</p>
          <p><strong class="text-holy-text-primary">{copy.projects.problemLabel}:</strong> {project.problem}</p>
          <p><strong class="text-holy-text-primary">{copy.projects.solutionLabel}:</strong> {project.solution}</p>
          <p><strong class="text-holy-text-primary">{copy.projects.impactLabel}:</strong> {project.impact}</p>
        </div>

        <div class="mt-6">
          <LinkButton href={project.link.startsWith("/#") ? localePath(lang, project.link.substring(1)) : project.link}>
            <Link class="size-4" />
            {copy.projects.cta}
          </LinkButton>
        </div>
      </article>
    ))}
  </div>
</div>



