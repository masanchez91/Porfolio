---
import Code from "./icons/Code.astro"
import NextJS from "./icons/NextJS.astro"
import ReactJS from "./icons/ReactJS.astro"
import TypeScript from "./icons/TypeScript.astro"
import { DEFAULT_LOCALE, getSiteCopy, type Locale } from "../i18n/site"

interface Props {
  lang?: Locale
}

const { lang = DEFAULT_LOCALE } = Astro.props
const copy = getSiteCopy(lang)
const serviceIcons = [Code, NextJS, TypeScript, ReactJS]
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  {
    copy.services.items.map(({ title, description, features }, index) => {
      const Icon = serviceIcons[index] ?? Code
      return (
      <article class="group bg-holy-dark-secondary/50 backdrop-blur-sm rounded-2xl p-6 border border-holy-neutral/20 hover:border-holy-action/50 transition-all duration-300 hover:shadow-lg hover:shadow-holy-action/10">
        <div class="flex items-start gap-4 mb-4">
          <div class="p-3 bg-holy-action/20 rounded-xl group-hover:bg-holy-action/30 transition-colors duration-300">
            <Icon class="size-6 text-holy-action" />
          </div>
          <div class="flex-1">
            <h3 class="font-heading text-h3 font-semibold text-holy-text-primary mb-2">
              {title}
            </h3>
          </div>
        </div>
        
        <p class="text-holy-text-secondary leading-relaxed mb-4">
          {description}
        </p>
        
        <ul class="space-y-2">
          {features.map((feature) => (
            <li class="flex items-center gap-2 text-sm text-holy-text-secondary">
              <span class="w-1.5 h-1.5 bg-holy-action rounded-full"></span>
              {feature}
            </li>
          ))}
        </ul>
        
      </article>
      )
    })
  }
</div>

<div class="mt-12 text-center">
  <div class="bg-holy-dark-secondary/30 backdrop-blur-sm rounded-2xl p-8 border border-holy-action/20">
    <h3 class="font-heading text-h3 font-semibold text-holy-text-primary mb-4">
      {copy.services.ctaTitle}
    </h3>
    <p class="text-holy-text-secondary mb-6 max-w-2xl mx-auto">
      {copy.services.ctaDescription}
    </p>
    <a 
      href="mailto:mauro@holy-code.com"
      class="inline-flex items-center gap-2 px-6 py-3 bg-holy-action hover:bg-holy-action/90 text-holy-text-primary rounded-full font-semibold transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-holy-action/25"
    >
      {copy.services.ctaButton}
      <span>✨</span>
    </a>
  </div>
</div> 