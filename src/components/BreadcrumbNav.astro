---
interface Props {
  items: Array<{
    name: string;
    href?: string;
  }>;
  homeAriaLabel?: string;
}

const { items, homeAriaLabel = "Go to home" } = Astro.props;

// Schema para breadcrumbs
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": item.name,
    ...(item.href && { "item": item.href })
  }))
};
---

<nav aria-label="Breadcrumb" class="breadcrumb-nav">
  <ol class="flex flex-wrap items-center gap-y-1 text-sm text-holy-text-secondary">
    {items.map((item, index) => (
      <li class="flex items-center">
        {index > 0 && (
          <span class="mx-2 text-holy-text-secondary opacity-60">•</span>
        )}
        {item.href ? (
          <a 
            href={item.href} 
            class="hover:text-holy-action transition-colors font-medium"
            aria-label={index === 0 ? homeAriaLabel : undefined}
          >
            {index === 0 && '🏠 '}{item.name}
          </a>
        ) : (
          <span class="text-holy-text-primary font-semibold">
            {item.name}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

<style>
  .breadcrumb-nav {
    background: rgba(22, 42, 63, 0.3);
    backdrop-filter: blur(8px);
    border: 1px solid var(--holy-border);
    border-radius: 1rem;
    padding: 1rem;
  }
  
  .breadcrumb-nav ol {
    margin: 0;
    padding: 0;
  }
  
  .breadcrumb-nav li {
    list-style: none;
    min-width: 0;
  }

  .breadcrumb-nav span,
  .breadcrumb-nav a {
    overflow-wrap: anywhere;
  }

  :root:not(.dark) .breadcrumb-nav {
    background: rgba(255, 255, 255, 0.92);
    border-color: rgba(15, 23, 42, 0.12);
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
    backdrop-filter: none;
  }
  
  @media (max-width: 640px) {
    .breadcrumb-nav {
      padding: 0.75rem;
      font-size: 0.875rem;
    }
  }
</style> 