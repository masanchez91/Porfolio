---
import { DEFAULT_LOCALE, getSiteCopy, localePath, swapLocaleInPath, type Locale } from "../i18n/site"
const currentYear = new Date().getFullYear()

interface Props {
  lang?: Locale
  esUrl?: string
  enUrl?: string
}

const { lang = DEFAULT_LOCALE, esUrl: esSwitchUrl, enUrl: enSwitchUrl } = Astro.props
const copy = getSiteCopy(lang)
const esUrl = esSwitchUrl ?? swapLocaleInPath(Astro.url.pathname, "es")
const enUrl = enSwitchUrl ?? swapLocaleInPath(Astro.url.pathname, "en")

const navItems = [
  {
    title: copy.nav.home,
    label: "inicio",
    url: localePath(lang, "/#inicio"),
    icon: "🏠"
  },
  {
    title: copy.nav.projects,
    label: "proyectos",
    url: localePath(lang, "/#proyectos"), 
    icon: "🚀"
  },
  {
    title: copy.nav.experience,
    label: "experiencia",
    url: localePath(lang, "/#experiencia"),
    icon: "💼"
  },
  {
    title: copy.nav.about,
    label: "agencia",
    url: localePath(lang, "/#agencia"),
    icon: "👤"
  },
  {
    title: copy.nav.ecosystem,
    label: "ecosistema", 
    url: localePath(lang, "/#ecosistema"),
    icon: "⚙️"
  },
  {
    title: copy.nav.contact,
    label: "contacto",
    url: localePath(lang, "/#contacto"),
    icon: "📧"
  },
  {
    title: copy.nav.blog,
    label: "blog",
    url: localePath(lang, "/blog"),
    icon: "📝"
  },
]
---

<!-- Botón hamburguesa -->
<button
  id="mobile-menu-button"
  class="xl:hidden fixed top-4 right-4 z-[9999] flex items-center justify-center w-12 h-12 rounded-xl shadow-lg backdrop-blur-sm"
  aria-label={lang === "en" ? "Open menu" : "Abrir menú"}
  type="button"
>
  <div class="hamburger">
    <span></span>
    <span></span>
    <span></span>
  </div>
</button>

<!-- Menú móvil -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[9998] hidden overflow-y-auto"
>
  <!-- Header fijo -->
  <div class="sticky top-0 z-10 flex items-center justify-between p-4 border-b border-holy-border">
    <div class="flex items-center space-x-3">
      <img
        src="/holycode.webp"
        alt="The Holy Code"
        class="w-10 h-10 rounded-full border-2 border-holy-action/70"
      />
      <span class="font-bold text-xl text-holy-text-primary">The Holy Code</span>
    </div>
    <button
      id="mobile-menu-close"
      class="flex items-center justify-center w-10 h-10 rounded-full bg-holy-dark-secondary text-holy-text-primary hover:bg-holy-action/20 transition-colors"
      aria-label={lang === "en" ? "Close menu" : "Cerrar menú"}
      type="button"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Contenido scrolleable -->
  <div class="flex flex-col min-h-full">
    <!-- Enlaces -->
    <div class="p-4 space-y-3">
      {navItems.map((item) => (
        <a
          href={item.url}
          class="mobile-nav-link flex items-center space-x-4 p-4 rounded-xl border transition-all"
        >
          <span class="text-2xl">
            {item.icon}
          </span>
          <span class="font-medium text-lg text-holy-text-primary">
            {item.title}
          </span>
          <svg class="w-6 h-6 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>

    <!-- Theme Toggle Section - SIEMPRE VISIBLE -->
    <div class="p-4 border-t border-holy-border">
      <div class="mb-4 flex items-center justify-center text-xs">
        <div class="lang-segment-mobile">
          <a href={esUrl} class={`lang-chip-mobile ${lang === "es" ? "is-active" : ""}`}>ES</a>
          <a href={enUrl} class={`lang-chip-mobile ${lang === "en" ? "is-active" : ""}`}>EN</a>
        </div>
      </div>
      <div class="space-y-4">
        <h3 class="text-holy-text-primary font-medium text-lg mb-4 text-center">🌙 {lang === "en" ? "Theme" : "Cambiar tema"}</h3>
        <div class="grid grid-cols-3 gap-3">
          <button
            class="theme-btn flex flex-col items-center p-3 border rounded-xl transition-all min-h-[72px]"
            data-theme="light"
          >
            <span class="text-2xl mb-1">☀️</span>
            <span class="text-sm font-medium">{lang === "en" ? "Light" : "Claro"}</span>
          </button>
          <button
            class="theme-btn flex flex-col items-center p-3 border rounded-xl transition-all min-h-[72px]"
            data-theme="dark"
          >
            <span class="text-2xl mb-1">🌙</span>
            <span class="text-sm font-medium">{lang === "en" ? "Dark" : "Oscuro"}</span>
          </button>
          <button
            class="theme-btn flex flex-col items-center p-3 border rounded-xl transition-all min-h-[72px]"
            data-theme="system"
          >
            <span class="text-2xl mb-1">💻</span>
            <span class="text-sm font-medium">{lang === "en" ? "System" : "Sistema"}</span>
          </button>
        </div>
      </div>
      
      <div class="text-center mt-6 pb-4">
        <p class="text-xs text-holy-text-secondary">
          © {currentYear} The Holy Code
        </p>
        <p class="text-xs text-holy-text-secondary mt-1">
          🚀 {lang === "en" ? "Building the future" : "Desarrollando el futuro"}
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  /* Hamburger básico */
  .hamburger {
    width: 24px;
    height: 18px;
    position: relative;
  }

  .hamburger span {
    display: block;
    position: absolute;
    height: 3px;
    width: 100%;
    background: currentColor;
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger span:nth-child(1) {
    top: 0;
  }

  .hamburger span:nth-child(2) {
    top: 7px;
  }

  .hamburger span:nth-child(3) {
    top: 14px;
  }

  /* Hamburger activo */
  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg);
    top: 7px;
    background: #10b981;
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg);
    top: 7px;
    background: #10b981;
  }

  /* Menú visible */
  #mobile-menu.menu-visible {
    display: block !important;
  }

  /* Prevenir scroll cuando está abierto */
  body.menu-open {
    overflow: hidden !important;
    position: fixed !important;
    width: 100% !important;
  }

  /* Enlaces de navegación */
  .mobile-nav-link {
    min-height: 62px;
    display: flex !important;
    align-items: center !important;
    color: var(--mobile-menu-text) !important;
    background: var(--mobile-card-bg) !important;
    border-color: var(--mobile-card-border) !important;
  }

  .mobile-nav-link:hover {
    transform: translateY(-1px);
    border-color: rgba(40, 167, 69, 0.45) !important;
  }

  :root {
    --mobile-menu-bg: rgba(15, 31, 46, 0.98);
    --mobile-menu-text: #ffffff;
    --mobile-card-bg: rgba(22, 42, 63, 0.82);
    --mobile-card-border: rgba(255, 255, 255, 0.18);
    --mobile-trigger-bg: rgba(15, 31, 46, 0.92);
    --mobile-trigger-text: #ffffff;
    --mobile-trigger-border: rgba(40, 167, 69, 0.6);
  }

  :root:not(.dark) {
    --mobile-menu-bg: rgba(248, 250, 252, 0.98);
    --mobile-menu-text: #0f172a;
    --mobile-card-bg: #ffffff;
    --mobile-card-border: rgba(15, 23, 42, 0.12);
    --mobile-trigger-bg: rgba(255, 255, 255, 0.96);
    --mobile-trigger-text: #0f172a;
    --mobile-trigger-border: rgba(15, 23, 42, 0.16);
  }

  #mobile-menu-button {
    background: var(--mobile-trigger-bg) !important;
    color: var(--mobile-trigger-text) !important;
    border: 1px solid var(--mobile-trigger-border) !important;
  }

  #mobile-menu {
    background: var(--mobile-menu-bg) !important;
    color: var(--mobile-menu-text) !important;
  }

  #mobile-menu .sticky {
    background: var(--mobile-menu-bg) !important;
  }

  .theme-btn {
    background: var(--mobile-card-bg) !important;
    border-color: var(--mobile-card-border) !important;
    color: var(--mobile-menu-text) !important;
  }

  .theme-btn.is-selected {
    border-color: rgba(40, 167, 69, 0.75) !important;
    box-shadow: 0 0 0 2px rgba(40, 167, 69, 0.18);
  }

  .lang-segment-mobile {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    padding: 0.2rem;
    border-radius: 9999px;
    border: 1px solid var(--mobile-card-border);
    background: var(--mobile-card-bg);
  }

  .lang-chip-mobile {
    border-radius: 9999px;
    padding: 0.2rem 0.55rem;
    color: var(--mobile-menu-text);
    border: 1px solid transparent;
  }

  .lang-chip-mobile.is-active {
    color: var(--holy-action);
    border-color: rgba(40, 167, 69, 0.55);
    background: color-mix(in srgb, var(--holy-action) 16%, transparent);
  }
</style>

<script>
  function initMobileMenu() {
    const menuButton = document.getElementById('mobile-menu-button');
    const menu = document.getElementById('mobile-menu');
    const closeButton = document.getElementById('mobile-menu-close');
    const hamburger = document.querySelector('.hamburger');
    const navLinks = document.querySelectorAll('.mobile-nav-link');
    
    if (!menuButton || !menu || !closeButton || !hamburger) {
      return;
    }

    // Evita listeners duplicados en navegación SPA
    if (menuButton instanceof HTMLElement && menuButton.dataset.initialized === 'true') {
      return;
    }
    if (menuButton instanceof HTMLElement) {
      menuButton.dataset.initialized = 'true';
    }

    let isOpen = false;
    let scrollTop = 0;

    function getThemePreference() {
      try {
        return localStorage.getItem('theme') || 'system';
      } catch {
        return 'system';
      }
    }

    function syncThemeButtons() {
      const current = getThemePreference();
      themeButtons.forEach((btn) => {
        const btnTheme = btn.getAttribute('data-theme');
        btn.classList.toggle('is-selected', btnTheme === current);
      });
    }

    function openMenu() {
      if (!menu || !hamburger) return;
      
      // Mostrar menú
      menu.style.display = 'block';
      menu.classList.add('menu-visible');
      
      // Cambiar hamburger
      hamburger.classList.add('active');
      
      // Prevenir scroll conservando posición actual
      scrollTop = window.scrollY || window.pageYOffset || 0;
      document.body.classList.add('menu-open');
      document.body.style.top = `-${scrollTop}px`;
      
      isOpen = true;
    }

    function closeMenu() {
      if (!menu || !hamburger) return;
      
      // Ocultar menú
      menu.style.display = 'none';
      menu.classList.remove('menu-visible');
      
      // Restaurar hamburger
      hamburger.classList.remove('active');
      
      // Restaurar scroll
      document.body.classList.remove('menu-open');
      document.body.style.top = '';
      window.scrollTo(0, scrollTop);
      
      isOpen = false;
    }

    // Event listeners
    menuButton.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    closeButton.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      closeMenu();
    });

    // Manejar navegación de enlaces
    navLinks.forEach((link, index) => {
      link.addEventListener('click', (e) => {
        const href = link.getAttribute('href');
        
        if (href) {
          if (href === '/blog' || href === '/es/blog' || href === '/en/blog') {
            // Enlaces externos - cerrar inmediatamente
            closeMenu();
          } else if (href.includes('#')) {
            // Enlaces de ancla - manejar especialmente
            e.preventDefault();
            const targetId = href.split('#')[1] || '';
            closeMenu();
            setTimeout(() => {
              const targetElement = document.getElementById(targetId);
              if (targetElement) {
                // Smooth scroll a la sección
                targetElement.scrollIntoView({ 
                  behavior: 'smooth',
                  block: 'start'
                });
              } else {
                // Fallback - ir a la página principal con el hash
                window.location.href = href;
              }
            }, 300);
          } else {
            // Otros enlaces - comportamiento normal
            setTimeout(closeMenu, 100);
          }
        }
      });
    });

    // Manejar theme toggle
    const themeButtons = document.querySelectorAll('.theme-btn');
    themeButtons.forEach(button => {
      button.addEventListener('click', () => {
        const theme = button.getAttribute('data-theme');
        
        if (theme) {
          try {
            localStorage.setItem('theme', theme);
            
            // Aplicar tema inmediatamente
            const isDark = theme === 'dark' || (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
            document.documentElement.classList.remove('light');
            document.documentElement.classList.toggle('dark', isDark);
            document.documentElement.dataset.theme = isDark ? 'dark' : 'light';
            syncThemeButtons();
          } catch (error) {
            console.error('❌ Error setting theme:', error);
          }
        }
      });
    });

    syncThemeButtons();

    // Cerrar con escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        closeMenu();
      }
    });
  }

  // Initialize
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileMenu);
  } else {
    initMobileMenu();
  }

  // Re-initialize on navigation
  document.addEventListener('astro:page-load', initMobileMenu);
</script> 