---
import MailIcon from "./icons/Mail.astro"
---

<div class="fixed bottom-6 right-6 z-50">
  <a 
    href="mailto:mauro@holy-code.com"
    class="group relative overflow-hidden flex items-center gap-3 px-6 py-4 bg-holy-action hover:bg-holy-action/90 text-holy-text-primary rounded-full shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105 border border-holy-action/20 backdrop-blur-sm"
    aria-label="Conectar por email"
  >
    <MailIcon class="size-5 group-hover:scale-110 transition-transform" />
    <span class="font-heading font-semibold text-button">Conectemos</span>
    <div class="cta-glow absolute inset-0 rounded-full pointer-events-none"></div>
  </a>
</div>

<style>
  /* Animación mucho más sutil, sin parpadeo agresivo */
  @keyframes cta-soft-breath {
    0%, 100% {
      transform: scale(1);
      opacity: 0.08;
    }
    50% {
      transform: scale(1.025);
      opacity: 0.16;
    }
  }

  .cta-glow {
    background: var(--holy-action);
    animation: cta-soft-breath 3.8s ease-in-out infinite;
  }

  /* Responsive: ocultar en pantallas muy pequeñas */
  @media (max-width: 480px) {
    .fixed {
      bottom: 4rem;
      right: 1rem;
    }
    
    .group {
      padding: 0.75rem 1rem;
    }
    
    .group span {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-glow {
      animation: none;
      opacity: 0.08;
    }
  }
</style> 